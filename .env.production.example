# Happy Backend - Production Environment Configuration
# Copy this to .env.production and fill in your values

# ════════════════════════════════════════════════════════════════════════════
# 🗄️ DATABASE CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════

# MongoDB Atlas (recommended for production)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
DATABASE_URL=mongodb+srv://your_username:your_password@cluster-xxxxx.mongodb.net/happy-db?retryWrites=true&w=majority

# Alternative: MongoDB Hetzner (self-managed, uncomment if using)
# DATABASE_URL=mongodb://user:password@mongodb-ip:27017/happy-db?authSource=admin

# ════════════════════════════════════════════════════════════════════════════
# 📮 REDIS CLOUD CONFIGURATION (for WebSocket scaling)
# ════════════════════════════════════════════════════════════════════════════

# Redis Cloud URL
# Get this from Redis Cloud console: https://redis.com/cloud/
# Format: redis://:PASSWORD@HOST:PORT/0
REDIS_URL=redis://:your_password@redis-xxxxx.cloud.redis.io:12345/0

# Alternative: Local Redis (for development)
# REDIS_URL=redis://localhost:6379/0

# Alternative: Redis Hetzner (self-managed)
# REDIS_URL=redis://:password@redis-ip:6379/0

# ════════════════════════════════════════════════════════════════════════════
# 🔐 JWT & SECURITY
# ════════════════════════════════════════════════════════════════════════════

# JWT Secret Key (use a strong, random value!)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-change-this-in-production-make-it-very-long-and-random

# JWT Token Expiration
# Format: "24h", "7d", "30d"
JWT_EXPIRATION=24h

# ════════════════════════════════════════════════════════════════════════════
# 🌐 APPLICATION CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════

# Node environment
NODE_ENV=production

# App port (should be 3000 in Docker)
PORT=3000

# CORS Origins (comma-separated, use '*' for dev only)
# Production: Only allow your Godot client domains
# Example: CORS_ORIGIN=https://your-domain.com,https://api.your-domain.com
CORS_ORIGIN=*

# Server instance ID (used for logging/identification)
# Auto-set by Docker INSTANCE_ID env var
INSTANCE_ID=app-server-1

# ════════════════════════════════════════════════════════════════════════════
# 📊 LOGGING & MONITORING
# ════════════════════════════════════════════════════════════════════════════

# Log level: error, warn, log, debug, verbose
LOG_LEVEL=log

# Rate limiting (requests per minute)
RATE_LIMIT_WINDOW_MS=900000      # 15 minutes
RATE_LIMIT_MAX_REQUESTS=1000     # 1000 requests

# ════════════════════════════════════════════════════════════════════════════
# 🎮 GAME CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════

# Maximum players per game session
MAX_PLAYERS_PER_SESSION=4

# WebSocket heartbeat interval (milliseconds)
WS_HEARTBEAT_INTERVAL=30000

# WebSocket heartbeat timeout (milliseconds)
WS_HEARTBEAT_TIMEOUT=60000

# ════════════════════════════════════════════════════════════════════════════
# 🔄 HORIZONTAL SCALING (Hetzner + Load Balancer)
# ════════════════════════════════════════════════════════════════════════════

# Enable Redis Adapter for WebSocket broadcast
ENABLE_REDIS_ADAPTER=true

# Trust proxy (for Load Balancer - important!)
# Set to 1 if behind a proxy (Hetzner LB, Nginx, etc.)
TRUST_PROXY=1

# ════════════════════════════════════════════════════════════════════════════
# 🔒 SECURITY HEADERS
# ════════════════════════════════════════════════════════════════════════════

# Content Security Policy
CSP_ENABLED=true

# HSTS (HTTP Strict Transport Security)
# Only set to true if you have valid SSL certificate
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000

# ════════════════════════════════════════════════════════════════════════════
# 📧 EMAIL CONFIGURATION (optional - for notifications)
# ════════════════════════════════════════════════════════════════════════════

# Email provider (sendgrid, mailgun, smtp)
EMAIL_PROVIDER=smtp

# SMTP Configuration (if using SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# SendGrid API Key (if using SendGrid)
SENDGRID_API_KEY=

# Mailgun API Key (if using Mailgun)
MAILGUN_API_KEY=

# ════════════════════════════════════════════════════════════════════════════
# 🧪 TESTING & DEVELOPMENT (set to false in production)
# ════════════════════════════════════════════════════════════════════════════

# Enable debug mode
DEBUG=false

# Enable test endpoints
ENABLE_TEST_ENDPOINTS=false

# ════════════════════════════════════════════════════════════════════════════
# Notes for Hetzner Deployment
# ════════════════════════════════════════════════════════════════════════════

# 1. MongoDB:
#    - Use MongoDB Atlas (easiest)
#    - Or create a MongoDB instance on Hetzner VPS
#    - Make sure firewall allows connections from app servers

# 2. Redis Cloud:
#    - Create free account at https://redis.com/cloud/
#    - Create database (pick same region as Hetzner servers)
#    - Copy connection URL to REDIS_URL
#    - Test: redis-cli -u $REDIS_URL ping → should return PONG

# 3. Load Balancer:
#    - Hetzner Load Balancer with Let's Encrypt certificate
#    - Services: HTTP (80) → HTTPS (443)
#    - Targets: app1, app2, app3 (your 3 servers)
#    - Health check: GET /health (port 3000)

# 4. Security:
#    - Change JWT_SECRET to something random and long
#    - Use https:// in CORS_ORIGIN
#    - Use strong database passwords
#    - Enable firewall on Hetzner servers (only 22, 80, 443)

# 5. Monitoring:
#    - Check logs: docker-compose logs app1
#    - Monitor Redis: redis-cli -u $REDIS_URL info
#    - Monitor MongoDB: MongoDB Atlas dashboard
#    - Monitor Servers: Hetzner Cloud console

# ════════════════════════════════════════════════════════════════════════════
